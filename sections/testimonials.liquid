{% if section.blocks.size > 0 %}
<section class="testimonials section-padding">
  <div class="container">
    <div class="testimonials__heading fade-in-up">
      <p class="label" style="margin-bottom: 0.8rem;">
        {{ section.settings.label | default: 'Bewertungen' }}
      </p>
      <h2 class="h2">{{ section.settings.heading | default: 'Was sie sagen' }}</h2>
    </div>
    <div class="testimonials__grid">
      {% for block in section.blocks %}
        {% if block.type == 'testimonial' %}
          <div class="testimonial fade-in-up" {{ block.shopify_attributes }}>
            <div class="testimonial__mark" aria-hidden="true">&ldquo;</div>
            <p class="testimonial__text">{{ block.settings.quote }}</p>
            <p class="testimonial__author">{{ block.settings.author }}</p>
            {% if block.settings.origin != blank %}
              <p class="testimonial__origin">{{ block.settings.origin }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "label", "label": "Abschnitts-Label", "default": "Bewertungen" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Was sie sagen" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Bewertung",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Zitat", "default": "Ein außergewöhnlicher Duft — geheimnisvoll, tief, unvergesslich. Er blieb über zwölf Stunden bei mir." },
        { "type": "text", "id": "author", "label": "Name", "default": "— M. Laurent" },
        { "type": "text", "id": "origin", "label": "Ort", "default": "Paris, Frankreich" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "Ein außergewöhnlicher Duft — geheimnisvoll, tief, unvergesslich. Er blieb über zwölf Stunden bei mir.", "author": "— M. Laurent", "origin": "Paris, Frankreich" } },
        { "type": "testimonial", "settings": { "quote": "Nuit De Lune ist wie nichts, was ich je erlebt habe. Elegant, selbstbewusst und zutiefst sinnlich.", "author": "— K. Hoffmann", "origin": "Berlin, Deutschland" } }
      ]
    }
  ]
}
{% endschema %}
