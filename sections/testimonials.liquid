{% if section.blocks.size > 0 %}
<section class="testimonials section-padding">
  <div class="container">

    <div class="testimonials__heading fade-in-up">
      <p class="label" style="margin-bottom: 0.8rem;">
        {{ section.settings.label | default: 'Reviews' }}
      </p>
      <h2 class="h2">{{ section.settings.heading | default: 'What They Say' }}</h2>
    </div>

    <div class="testimonials__grid">
      {% for block in section.blocks %}
        {% if block.type == 'testimonial' %}
          <div class="testimonial fade-in-up" {{ block.shopify_attributes }}>
            <div class="testimonial__mark" aria-hidden="true">&ldquo;</div>
            <p class="testimonial__text">{{ block.settings.quote }}</p>
            <p class="testimonial__author">{{ block.settings.author }}</p>
            {% if block.settings.origin != blank %}
              <p class="testimonial__origin">{{ block.settings.origin }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "What They Say"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "An extraordinary fragrance — mysterious, deep, unforgettable. It stayed with me for over twelve hours."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "— M. Laurent"
        },
        {
          "type": "text",
          "id": "origin",
          "label": "Location or subtitle",
          "default": "Paris, France"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "An extraordinary fragrance — mysterious, deep, unforgettable. It stayed with me for over twelve hours.",
            "author": "— M. Laurent",
            "origin": "Paris, France"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Nuit De Lune is unlike anything I have encountered before. Elegant, confident, and deeply sensual.",
            "author": "— K. Hoffmann",
            "origin": "Berlin, Germany"
          }
        }
      ]
    }
  ]
}
{% endschema %}
