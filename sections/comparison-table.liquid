<section class="comparison">
  <div class="comparison__inner">

    <h2 class="comparison__heading">{{ section.settings.heading | default: 'Wie wir im Vergleich abschneiden' }}</h2>

    <div class="comparison__table">

      <!-- Feature Labels -->
      <div class="comparison__features">
        <div class="comparison__feature-header"></div>
        {% for block in section.blocks %}
          <div class="comparison__feature-row">{{ block.settings.label }}</div>
        {% endfor %}
      </div>

      <!-- Venatici Column -->
      <div class="comparison__col comparison__col--us">
        <div class="comparison__col-header">
          <img
            src="{{ section.settings.product_image | default: 'https://res.cloudinary.com/dj4rhk89z/image/upload/v1778800358/IMG_0286_vxf0er.jpg' }}"
            alt="Venatici Nuit De Lune"
            class="comparison__col-img"
            width="80"
            height="80"
          >
          <span class="comparison__col-name">Venatici<br>Nuit De Lune</span>
        </div>
        {% for block in section.blocks %}
          <div class="comparison__cell comparison__cell--check">✓</div>
        {% endfor %}
      </div>

      <!-- Competitor Column -->
      <div class="comparison__col comparison__col--them">
        <div class="comparison__col-header">
          <div class="comparison__col-img comparison__col-img--placeholder">
            <svg viewBox="0 0 60 80" xmlns="http://www.w3.org/2000/svg" width="40" height="56" opacity="0.4">
              <rect x="15" y="0" width="30" height="10" rx="2" fill="#fff"/>
              <rect x="5" y="10" width="50" height="65" rx="3" fill="#fff"/>
            </svg>
          </div>
          <span class="comparison__col-name">Designer-<br>Parfums</span>
        </div>
        {% for block in section.blocks %}
          <div class="comparison__cell comparison__cell--cross">✕</div>
        {% endfor %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vergleichstabelle",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Wie wir im Vergleich abschneiden"
    },
    {
      "type": "text",
      "id": "product_image",
      "label": "Produktbild URL",
      "default": "https://res.cloudinary.com/dj4rhk89z/image/upload/v1778800358/IMG_0286_vxf0er.jpg"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Merkmal",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Merkmal",
          "default": "40% Parfumöl"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vergleichstabelle",
      "blocks": [
        { "type": "feature", "settings": { "label": "40% Parfumöl" } },
        { "type": "feature", "settings": { "label": "Langanhaltend 8–12 Std." } },
        { "type": "feature", "settings": { "label": "Handgefertigt" } },
        { "type": "feature", "settings": { "label": "Premium-Verpackung" } },
        { "type": "feature", "settings": { "label": "30 Tage Garantie" } }
      ]
    }
  ]
}
{% endschema %}
