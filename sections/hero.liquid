<section class="hero" id="hero">

  {% if section.settings.video_url != blank %}
    <video
      class="hero__video"
      src="{{ section.settings.video_url }}"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    ></video>
  {% elsif section.settings.bg_image %}
    <div
      class="hero__bg"
      style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');"
    ></div>
  {% endif %}

  <div
    class="hero__overlay"
    style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
  ></div>

  <div class="hero__content">
    <p class="label hero__label fade-in-up">
      {{ section.settings.label | default: 'Venatici Parfums' }}
    </p>

    <h1 class="display hero__title fade-in-up">
      {{ section.settings.heading | default: 'Nuit De Lune' }}
    </h1>

    <p class="label hero__sub fade-in-up" style="color: var(--color-text-muted); letter-spacing: 0.32em;">
      {{ section.settings.subheading | default: 'Un parfum de nuit' }}
    </p>

    {% if section.settings.cta_label != blank %}
      <a
        href="{{ section.settings.cta_link | default: '#featured-product' }}"
        class="btn btn--primary fade-in-up"
      >
        {{ section.settings.cta_label }}
      </a>
    {% endif %}
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <div class="hero__scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Venatici Parfums" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Nuit De Lune" },
    { "type": "text", "id": "subheading", "label": "Unterzeile", "default": "Un parfum de nuit" },
    { "type": "text", "id": "cta_label", "label": "Button-Text", "default": "Discover" },
    { "type": "url", "id": "cta_link", "label": "Button-Link" },
    { "type": "text", "id": "video_url", "label": "Video-URL (Google Drive / MP4)" },
    { "type": "image_picker", "id": "bg_image", "label": "Hintergrundbild (Fallback)" },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay-Deckkraft",
      "min": 20,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 65
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
