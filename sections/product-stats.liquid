<section class="product-stats" id="charakteristika">
  <div class="product-stats__inner">

    <p class="label product-stats__eyebrow fade-in-up">
      N° I &mdash; Die Charakteristika
    </p>

    <h2 class="product-stats__headline fade-in-up">
      Eine <em>Studie</em><br>in Vollendung
    </h2>

    <div class="product-stats__grid">
      <div class="product-stats__item fade-in-up">
        <div class="product-stats__number">40<span class="product-stats__unit">%</span></div>
        <div class="product-stats__label">Parfumöl</div>
      </div>
      <div class="product-stats__item fade-in-up">
        <div class="product-stats__number">75<span class="product-stats__unit">ml</span></div>
        <div class="product-stats__label">Flakon</div>
      </div>
      <div class="product-stats__item fade-in-up">
        <div class="product-stats__number">8–12<span class="product-stats__unit">h</span></div>
        <div class="product-stats__label">Haltbarkeit</div>
      </div>
      <div class="product-stats__item fade-in-up">
        <div class="product-stats__number"><em>VII</em></div>
        <div class="product-stats__label">Ingredienzien</div>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Produkt-Statistiken",
  "settings": [],
  "presets": [{ "name": "Produkt-Statistiken" }]
}
{% endschema %}
