<section class="fragrance-story section-padding" id="fragrance-story">
  <div class="fragrance-story__inner">

    <p class="label fragrance-story__label fade-in-up">
      {{ section.settings.label | default: 'The Story' }}
    </p>

    {% if section.settings.quote != blank %}
      <blockquote class="fragrance-story__quote fade-in-up">
        {{ section.settings.quote }}
      </blockquote>
    {% endif %}

    <div class="fragrance-story__divider fade-in-up"></div>

    {% if section.settings.body != blank %}
      <div class="fragrance-story__body body-text fade-in-up">
        {{ section.settings.body }}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Fragrance Story",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "The Story"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Pull quote",
      "default": "Born from the silence of a moonlit night — a fragrance that speaks before words do."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Venatici Nuit De Lune is a rare olfactory journey into the depths of night. Inspired by the quiet grandeur of starlit skies and the warmth of ancient woods, this fragrance weaves together the finest raw materials from around the world into a composition of extraordinary depth and longevity.</p>"
    }
  ],
  "presets": [
    {
      "name": "Fragrance Story"
    }
  ]
}
{% endschema %}
