<section class="fragrance-notes section-padding" id="fragrance-notes">
  <div class="container">

    <div class="fragrance-notes__heading fade-in-up">
      <p class="label" style="margin-bottom: 0.8rem;">
        {{ section.settings.label | default: 'Composition' }}
      </p>
      <h2 class="h2">{{ section.settings.heading | default: 'The Notes' }}</h2>
    </div>

    <div class="fragrance-notes__grid">
      {% for block in section.blocks %}
        {% if block.type == 'note_tier' %}
          <div class="note-tier fade-in-up" {{ block.shopify_attributes }}>
            <div class="note-tier__ornament" aria-hidden="true">◆</div>
            <p class="label note-tier__label">{{ block.settings.tier_label }}</p>
            <ul class="note-tier__list">
              {% assign notes = block.settings.notes_list | split: "\n" %}
              {% for note in notes %}
                {% assign note_trimmed = note | strip %}
                {% if note_trimmed != blank %}
                  <li class="note-tier__item">{{ note_trimmed }}</li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Fragrance Notes",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Composition"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "The Notes"
    }
  ],
  "blocks": [
    {
      "type": "note_tier",
      "name": "Note Tier",
      "settings": [
        {
          "type": "text",
          "id": "tier_label",
          "label": "Tier label",
          "default": "Top Notes"
        },
        {
          "type": "textarea",
          "id": "notes_list",
          "label": "Notes (one per line)",
          "default": "Bergamot\nBlack Pepper\nCardamom"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fragrance Notes",
      "blocks": [
        {
          "type": "note_tier",
          "settings": {
            "tier_label": "Top Notes",
            "notes_list": "Bergamot\nBlack Pepper\nCardamom"
          }
        },
        {
          "type": "note_tier",
          "settings": {
            "tier_label": "Heart Notes",
            "notes_list": "Bulgarian Rose\nJasmine Sambac\nIris"
          }
        },
        {
          "type": "note_tier",
          "settings": {
            "tier_label": "Base Notes",
            "notes_list": "Oud\nAmber\nSandalwood\nMusk"
          }
        }
      ]
    }
  ]
}
{% endschema %}
