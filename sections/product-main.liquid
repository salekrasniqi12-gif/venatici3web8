<div class="product-main" data-product-section>

  {%- assign product_img = section.settings.fallback_image -%}
  {%- if product.featured_image -%}
    {%- assign product_img = product.featured_image | image_url: width: 1000 -%}
  {%- endif -%}

  <!-- Gallery -->
  <div class="product-main__gallery">
    <div class="product-main__image-wrap">
      <img
        class="product-main__image js-product-main-img"
        src="{{ product_img }}"
        alt="{{ product.title | default: 'Venatici Nuit De Lune' | escape }}"
        width="800"
        height="900"
        loading="eager"
      >
    </div>
    {%- if product.images.size > 1 -%}
    <div class="product-main__thumbs">
      {%- for img in product.images -%}
        <button
          class="product-main__thumb{% if forloop.first %} product-main__thumb--active{% endif %}"
          data-full="{{ img | image_url: width: 1000 }}"
          aria-label="Bild {{ forloop.index }}"
        >
          <img src="{{ img | image_url: width: 200 }}" alt="{{ img.alt | escape }}" width="80" height="80" loading="lazy">
        </button>
      {%- endfor -%}
    </div>
    {%- endif -%}
  </div>

  <!-- Info -->
  <div class="product-main__info">

    <h1 class="product-main__title">
      {{- product.title | upcase | default: 'VENATICI NUIT DE LUNE' -}}
    </h1>

    <div class="product-main__price">
      {%- if product.selected_or_first_available_variant -%}
        {{ product.selected_or_first_available_variant.price | money }}
      {%- else -%}
        {{ section.settings.fallback_price }}
      {%- endif -%}
    </div>

    <hr class="product-main__divider">

    {%- if section.settings.quote != blank -%}
      <blockquote class="product-main__quote">„{{ section.settings.quote }}"</blockquote>
    {%- endif -%}

    <!-- Fragrance Notes from Blocks -->
    {%- if section.blocks.size > 0 -%}
    <div class="product-main__notes">
      {%- for block in section.blocks -%}
        {%- if block.type == 'note_tier' -%}
          <div class="product-main__note-row" {{ block.shopify_attributes }}>
            <span class="product-main__note-label">{{ block.settings.tier_label }}:</span>
            <span class="product-main__note-value">
              {%- assign notes_raw = block.settings.notes_list | newline_to_br -%}
              {{- notes_raw | replace: '<br />', ', ' | replace: '<br>', ', ' | strip -}}
            </span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- endif -%}

    <!-- Attributes -->
    <div class="product-main__attrs">
      {%- if section.settings.character != blank -%}
        <div class="product-main__attr"><b>Duftcharakter:</b> {{ section.settings.character }}</div>
      {%- endif -%}
      {%- if section.settings.occasion != blank -%}
        <div class="product-main__attr"><b>Anlass:</b> {{ section.settings.occasion }}</div>
      {%- endif -%}
      {%- if section.settings.gender != blank -%}
        <div class="product-main__attr"><b>Tragbarkeit:</b> {{ section.settings.gender }}</div>
      {%- endif -%}
      {%- if section.settings.season != blank -%}
        <div class="product-main__attr"><b>Jahreszeit:</b> {{ section.settings.season }}</div>
      {%- endif -%}
    </div>

    <!-- Bundle Picker -->
    {%- if product.variants.size > 1 -%}
    <div class="bundle-picker">
      {%- for variant in product.variants -%}
        <button
          type="button"
          class="bundle-option{% if forloop.first %} bundle-option--active{% endif %}{% if forloop.last %} bundle-option--featured{% endif %}"
          data-variant-id="{{ variant.id }}"
          data-price="{{ variant.price }}"
        >
          <span class="bundle-option__name">{{ variant.title }}</span>
          {%- if forloop.last and product.variants.size > 1 -%}
            {%- assign first_price = product.variants.first.price -%}
            {%- assign savings = first_price | times: 2 | minus: variant.price -%}
            {%- if savings > 0 -%}
              <span class="bundle-option__badge">SPARE {{ savings | money }}</span>
            {%- endif -%}
          {%- endif -%}
          <span class="bundle-option__price">{{ variant.price | money }}</span>
        </button>
      {%- endfor -%}
    </div>
    {%- endif -%}

    <!-- Form -->
    <form action="/cart/add" method="post" data-atc-form>
      {%- if product.selected_or_first_available_variant -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-input>
      {%- else -%}
        <input type="hidden" name="id" value="" data-variant-input>
      {%- endif -%}
      <input type="hidden" name="quantity" value="1">

      {%- if section.settings.show_qty and product.variants.size == 1 -%}
        <div class="product-main__qty">
          <label class="product-main__qty-label">Menge:</label>
          <div class="qty-wrap product-main__qty-wrap">
            <button type="button" class="qty-btn" data-action="decrease" aria-label="Weniger">−</button>
            <input type="number" name="quantity" class="qty-input" value="1" min="1">
            <button type="button" class="qty-btn" data-action="increase" aria-label="Mehr">+</button>
          </div>
        </div>
      {%- endif -%}

      <button
        type="submit"
        class="product-main__atc-btn"
        data-atc-btn
        {% unless product.available or section.settings.force_available %}aria-disabled="true"{% endunless %}
      >
        {%- if product.available or section.settings.force_available -%}
          ZUM WARENKORB HINZUFÜGEN
        {%- else -%}
          AUSVERKAUFT
        {%- endif -%}
      </button>
      <p class="atc-error"></p>
    </form>

    <!-- Trust Badges -->
    <div class="product-main__trust">
      <div class="trust-badge">
        <span class="trust-badge__icon">↺</span>
        <div class="trust-badge__text">
          <strong>30 Tage Geld-zurück-Garantie</strong>
          <span>Nicht überzeugt? Vollständige Rückerstattung.</span>
        </div>
      </div>
      <div class="trust-badge">
        <span class="trust-badge__icon">&#128230;</span>
        <div class="trust-badge__text">
          <strong>Schneller Versand</strong>
          <span>Versand innerhalb von 2–3 Werktagen</span>
        </div>
      </div>
    </div>

    <!-- Payment Icons -->
    {% render 'payment-icons', style: 'light' %}

    <!-- Description Accordion -->
    {%- assign desc = product.description -%}
    {%- if desc == blank -%}{%- assign desc = section.settings.description -%}{%- endif -%}
    {%- if desc != blank -%}
    <div class="product-main__accordion">
      <button class="product-main__accordion-btn" aria-expanded="true">
        <span>BESCHREIBUNG</span>
        <span class="product-main__accordion-chevron">−</span>
      </button>
      <div class="product-main__accordion-body">
        <div class="product-main__accordion-content">{{ desc }}</div>
      </div>
    </div>
    {%- endif -%}

    <!-- Inhaltsstoffe Accordion -->
    <div class="product-main__accordion">
      <button class="product-main__accordion-btn" aria-expanded="false">
        <span>INHALTSSTOFFE</span>
        <span class="product-main__accordion-chevron">+</span>
      </button>
      <div class="product-main__accordion-body" style="display:none">
        <div class="product-main__accordion-content">
          <p>Alcohol Denat., Parfum (Fragrance), Aqua (Water), Geraniol, Citronellol, Benzyl Alcohol, Citral.</p>
          <p style="margin-top:0.75rem; font-size:0.8rem; color:#aaa;">75ml · 80% Vol.</p>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Sticky ATC -->
<div class="product-sticky-atc" id="product-sticky-atc" aria-hidden="true">
  <div class="product-sticky-atc__inner">
    <span class="product-sticky-atc__name">{{ product.title | default: 'Venatici Nuit De Lune' }}</span>
    <button class="product-sticky-atc__btn js-sticky-atc-trigger">ZUM WARENKORB HINZUFÜGEN</button>
  </div>
</div>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    {
      "type": "image_picker",
      "id": "fallback_image_picker",
      "label": "Produktbild (Fallback)"
    },
    {
      "type": "text",
      "id": "fallback_image",
      "label": "Produktbild URL (Cloudinary)",
      "default": "https://res.cloudinary.com/dj4rhk89z/image/upload/v1778800358/IMG_0286_vxf0er.jpg"
    },
    {
      "type": "text",
      "id": "fallback_price",
      "label": "Preis (Fallback)",
      "default": "€50,00"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Kurzzitat",
      "default": "Unaufdringlich, aber präsent. Genau diese Balance habe ich gesucht."
    },
    {
      "type": "text",
      "id": "character",
      "label": "Duftcharakter",
      "default": "samtig, warm, orientalisch"
    },
    {
      "type": "text",
      "id": "occasion",
      "label": "Anlass",
      "default": "Abend, besondere Anlässe"
    },
    {
      "type": "text",
      "id": "gender",
      "label": "Tragbarkeit",
      "default": "Unisex"
    },
    {
      "type": "text",
      "id": "season",
      "label": "Jahreszeit",
      "default": "Herbst & Winter"
    },
    {
      "type": "checkbox",
      "id": "show_qty",
      "label": "Mengenauswahl anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "force_available",
      "label": "Immer als verfügbar anzeigen",
      "default": true
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Beschreibung (Fallback)",
      "default": "<p>Venatici Nuit De Lune ist eine seltene olfaktorische Reise in die Tiefen der Nacht. Inspiriert von der stillen Erhabenheit sternenklarer Himmel und der Wärme uralter Wälder, verwebt dieser Duft die feinsten Rohstoffe aus aller Welt zu einer Komposition von außerordentlicher Tiefe und Langlebigkeit.</p><p>Die Komposition eröffnet mit der cremigen Wärme von Kokosnuss und gerösteter Haselnuss. Im Herzen entfalten sich Rose und Neroli — blühend, strahlend, von seltener Reinheit. Die Basis aus Vanille, Moschus und Zedernholz hinterlässt eine langanhaltende, holzige Spur.</p><p>Nuit De Lune wirkt nicht laut, sondern erhebend. Ein Duft mit Ausstrahlung, Balance und Tiefe — geschaffen für Menschen, die Präsenz durch Stille zeigen.</p>"
    }
  ],
  "blocks": [
    {
      "type": "note_tier",
      "name": "Duftnote",
      "settings": [
        {
          "type": "text",
          "id": "tier_label",
          "label": "Bezeichnung",
          "default": "Kopfnote"
        },
        {
          "type": "textarea",
          "id": "notes_list",
          "label": "Noten (eine pro Zeile)",
          "default": "Kokosnuss\nHaselnuss"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Main",
      "blocks": [
        {
          "type": "note_tier",
          "settings": {
            "tier_label": "Kopfnote",
            "notes_list": "Kokosnuss\nHaselnuss"
          }
        },
        {
          "type": "note_tier",
          "settings": {
            "tier_label": "Herznote",
            "notes_list": "Rose\nNeroli"
          }
        },
        {
          "type": "note_tier",
          "settings": {
            "tier_label": "Basisnote",
            "notes_list": "Vanille\nMoschus\nZedernholz"
          }
        }
      ]
    }
  ]
}
{% endschema %}
