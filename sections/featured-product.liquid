{% assign product = section.settings.product %}
{% if product == blank %}
  {% assign product = all_products['venatici-nuit-de-lune'] %}
{% endif %}

<section class="featured-product" id="featured-product" data-product-section>
  <div class="featured-product__grid">

    <a
      class="featured-product__image-wrap"
      href="{{ product.url | default: '/products/venatici-nuit-de-lune' }}"
      aria-label="{{ product.title | default: 'Venatici Nuit De Lune' }}"
    >
      {% if product != blank and product.featured_image %}
        <img
          class="featured-product__image"
          src="{{ product.featured_image | image_url: width: 1200 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="1200"
          loading="eager"
        >
      {% else %}
        <img
          class="featured-product__image"
          src="https://res.cloudinary.com/dj4rhk89z/image/upload/v1778800358/IMG_0286_vxf0er.jpg"
          alt="Venatici Nuit De Lune"
          width="1200"
          loading="eager"
        >
      {% endif %}
    </a>

    <div class="featured-product__info">
      <p class="label featured-product__label fade-in-up">
        {{ section.settings.section_label | default: 'Der Duft' }}
      </p>

      {% if product != blank %}
        <h2 class="featured-product__title fade-in-up">{{ product.title }}</h2>
      {% else %}
        <h2 class="featured-product__title fade-in-up">Venatici Nuit De Lune</h2>
      {% endif %}

      {% if product != blank and product.price > 0 %}
        <div class="featured-product__price fade-in-up">{{ product.price | money }}</div>
      {% elsif section.settings.fallback_price != blank %}
        <div class="featured-product__price fade-in-up">{{ section.settings.fallback_price }}</div>
      {% endif %}

      {% if product != blank and product.description != blank %}
        <div class="featured-product__description body-text fade-in-up">{{ product.description }}</div>
      {% else %}
        <div class="featured-product__description body-text fade-in-up">
          Eine seltene olfaktorische Reise in die Tiefen der Nacht. Inspiriert von der stillen Erhabenheit sternenklarer Himmel — von außerordentlicher Tiefe und Langlebigkeit.
        </div>
      {% endif %}

      <ul class="featured-product__notes-inline fade-in-up">
        <li><span class="fp-note-tier">Kopf</span><span class="fp-note-list">Kokosnuss · Haselnuss</span></li>
        <li><span class="fp-note-tier">Herz</span><span class="fp-note-list">Rose · Neroli</span></li>
        <li><span class="fp-note-tier">Basis</span><span class="fp-note-list">Vanille · Moschus · Zedernholz</span></li>
      </ul>

      {% if product != blank %}
        <form action="/cart/add" method="post" data-atc-form class="fade-in-up">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          {% if product.variants.size > 1 %}
            <div class="product-options">
              <label class="product-option__label" for="variant-select-{{ section.id }}">
                {{ product.options.first }}
              </label>
              <select class="variant-select" id="variant-select-{{ section.id }}" name="id">
                {% for variant in product.variants %}
                  <option
                    value="{{ variant.id }}"
                    data-variant-id="{{ variant.id }}"
                    data-price="{{ variant.price }}"
                    data-available="{{ variant.available }}"
                    {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                    {% unless variant.available %}disabled{% endunless %}
                  >
                    {{ variant.title }}{% unless variant.available %} – Ausverkauft{% endunless %}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% endif %}

          {% if section.settings.show_qty %}
            <div class="qty-wrap">
              <button type="button" class="qty-btn" data-action="decrease" aria-label="Menge verringern">−</button>
              <input class="qty-input" type="number" name="quantity" value="1" min="1" aria-label="{{ 'product.quantity' | t }}">
              <button type="button" class="qty-btn" data-action="increase" aria-label="Menge erhöhen">+</button>
            </div>
          {% endif %}

          <button type="submit" class="btn btn--primary" data-atc-btn>
            In den Warenkorb
          </button>

          <p class="atc-error" role="alert" aria-live="assertive"></p>
        </form>
      {% else %}
        {% if section.settings.show_qty %}
          <div class="qty-wrap fade-in-up">
            <button type="button" class="qty-btn" data-action="decrease" aria-label="Menge verringern">−</button>
            <input class="qty-input" type="number" name="quantity" value="1" min="1">
            <button type="button" class="qty-btn" data-action="increase" aria-label="Menge erhöhen">+</button>
          </div>
        {% endif %}
        <a href="/products" class="btn btn--primary fade-in-up">In den Warenkorb</a>
      {% endif %}

      <!-- Payment Icons -->
      <div class="fade-in-up">
        {% render 'payment-icons', style: 'dark' %}
      </div>

      <!-- Trust Badges -->
      <div class="featured-product__trust fade-in-up">
        <div class="fp-trust-badge">
          <span class="fp-trust-badge__icon">↺</span>
          <span class="fp-trust-badge__text">30 Tage Geld-zurück-Garantie</span>
        </div>
        <div class="fp-trust-badge">
          <span class="fp-trust-badge__icon">&#128230;</span>
          <span class="fp-trust-badge__text">Versand in 2–3 Werktagen</span>
        </div>
      </div>

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Featured Product",
  "settings": [
    { "type": "product", "id": "product", "label": "Produkt" },
    { "type": "text", "id": "fallback_price", "label": "Preis-Anzeige (z.B. €79,00)", "default": "€79,00" },
    { "type": "text", "id": "section_label", "label": "Abschnitts-Label", "default": "Der Duft" },
    { "type": "checkbox", "id": "show_qty", "label": "Mengenauswahl anzeigen", "default": true }
  ],
  "presets": [{ "name": "Featured Product" }]
}
{% endschema %}
