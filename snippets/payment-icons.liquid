{% comment %}
  SVG Payment Icons
  Usage: {% render 'payment-icons', style: 'dark' %} or style: 'light'
{% endcomment %}

{% assign icon_style = style | default: 'light' %}
{% if icon_style == 'dark' %}
  {% assign card_fill = '#1a1a1a' %}
  {% assign card_stroke = 'rgba(255,255,255,0.15)' %}
{% else %}
  {% assign card_fill = '#ffffff' %}
  {% assign card_stroke = '#e0e0e0' %}
{% endif %}

<div class="payment-icons-row">

  <!-- PayPal -->
  <span class="payment-icon-wrap" aria-label="PayPal">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" width="52" height="32" role="img" aria-hidden="true">
      <rect width="60" height="38" rx="4" fill="{{ card_fill }}" stroke="{{ card_stroke }}" stroke-width="1"/>
      <text x="8" y="25" font-family="Arial,Helvetica,sans-serif" font-weight="900" font-style="italic" font-size="14" fill="#003087">Pay</text>
      <text x="30" y="25" font-family="Arial,Helvetica,sans-serif" font-weight="900" font-style="italic" font-size="14" fill="#009cde">Pal</text>
    </svg>
  </span>

  <!-- Apple Pay -->
  <span class="payment-icon-wrap" aria-label="Apple Pay">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" width="52" height="32" role="img" aria-hidden="true">
      <rect width="60" height="38" rx="4" fill="{{ card_fill }}" stroke="{{ card_stroke }}" stroke-width="1"/>
      {% if icon_style == 'dark' %}
        {% assign apple_color = '#ffffff' %}
      {% else %}
        {% assign apple_color = '#000000' %}
      {% endif %}
      <!-- Apple logo path -->
      <path d="M22 12.5c.9-1.1.8-2.6.8-2.6s-1.4.1-2.3 1.2c-.8 1-1 2.4-1 2.4s1.6.1 2.5-1zm1.2 1.7c-1.4-.1-2.6.8-3.2.8-.7 0-1.8-.7-3-.7-1.5 0-2.9.9-3.7 2.2-1.6 2.7-.4 6.7 1.1 8.9.8 1.1 1.7 2.3 2.9 2.2 1.1 0 1.6-.7 3-.7s1.8.7 3 .7c1.2 0 2-1.1 2.8-2.2.9-1.3 1.2-2.5 1.2-2.6s-2.3-1-2.3-3.7c0-2.3 1.9-3.4 1.9-3.5-.9-1.5-2.5-1.4-2.7-1.4z" fill="{{ apple_color }}"/>
      <text x="34" y="25" font-family="Arial,Helvetica,sans-serif" font-weight="600" font-size="11" fill="{{ apple_color }}">Pay</text>
    </svg>
  </span>

  <!-- Mastercard -->
  <span class="payment-icon-wrap" aria-label="Mastercard">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" width="52" height="32" role="img" aria-hidden="true">
      <rect width="60" height="38" rx="4" fill="{{ card_fill }}" stroke="{{ card_stroke }}" stroke-width="1"/>
      <circle cx="24" cy="19" r="9.5" fill="#EB001B"/>
      <circle cx="36" cy="19" r="9.5" fill="#F79E1B"/>
      <path d="M30 11.2a9.5 9.5 0 0 1 0 15.6 9.5 9.5 0 0 1 0-15.6z" fill="#FF5F00"/>
    </svg>
  </span>

  <!-- Visa -->
  <span class="payment-icon-wrap" aria-label="Visa">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" width="52" height="32" role="img" aria-hidden="true">
      <rect width="60" height="38" rx="4" fill="{{ card_fill }}" stroke="{{ card_stroke }}" stroke-width="1"/>
      <text x="30" y="25" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-weight="900" font-style="italic" font-size="18" fill="#1A1F71" letter-spacing="1">VISA</text>
    </svg>
  </span>

  <!-- Klarna -->
  <span class="payment-icon-wrap" aria-label="Klarna">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" width="52" height="32" role="img" aria-hidden="true">
      <rect width="60" height="38" rx="4" fill="#FFB3C7" stroke="#FFB3C7" stroke-width="1"/>
      <text x="30" y="25" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-weight="700" font-size="12" fill="#000000">Klarna</text>
    </svg>
  </span>

  <!-- American Express -->
  <span class="payment-icon-wrap" aria-label="American Express">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 38" width="52" height="32" role="img" aria-hidden="true">
      <rect width="60" height="38" rx="4" fill="#016fd0" stroke="#016fd0" stroke-width="1"/>
      <text x="30" y="18" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-weight="700" font-size="7" fill="#ffffff" letter-spacing="0.5">AMERICAN</text>
      <text x="30" y="28" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-weight="700" font-size="7" fill="#ffffff" letter-spacing="0.5">EXPRESS</text>
    </svg>
  </span>

</div>
